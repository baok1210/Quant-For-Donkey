# ============================================
# SOLANA DCA AI LEARNER - API CONFIGURATION
# ============================================

# ============================================
# AI PROVIDERS - Chọn 1 hoặc nhiều providers
# ============================================

# ---- OpenRouter (RECOMMENDED - 300+ models) ----
# Đăng ký tại: https://openrouter.ai/settings
# Models: gpt-5.4, claude-sonnet-4.6, gemini-2.5-pro, deepseek-r1, etc.
OPENROUTER_API_KEY=sk-or-xxxxxxxx

# ---- OpenAI (GPT) ----
# Đăng ký tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxx

# ---- Anthropic (Claude) ----
# Đăng ký tại: https://www.anthropic.com/api
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ---- Google Gemini ----
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxx

# ---- DeepSeek (Free!) ----
# Đăng ký tại: https://platform.deepseek.com
DEEPSEEK_API_KEY=xxxxxxxx

# ---- Together AI ----
# Đăng ký tại: https://together.ai
TOGETHER_API_KEY=xxxxxxxx

# ---- Groq (Fast!) ----
# Đăng ký tại: https://console.groq.com
GROQ_API_KEY=xxxxxxxx

# ---- Qwen (Alibaba) ----
QWEN_API_KEY=xxxxxxxx

# ---- Custom LLM (your own server) ----
# API Key cho custom endpoint (để trống nếu không cần)
CUSTOM_API_KEY=
# Endpoint URL (VD: http://localhost:1234/v1)
CUSTOM_ENDPOINT_URL=

# ---- OAuth2 (nếu dùng browser login) ----
# Chỉ cần thiết lập tại provider dashboard
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_CLIENT_SECRET=

# ============================================
# EXCHANGE APIs (Trading)
# ============================================
BINANCE_API_KEY=your_binance_key
BINANCE_SECRET_KEY=your_binance_secret

OKX_API_KEY=your_okx_key
OKX_SECRET_KEY=your_okx_secret
OKX_PASSPHRASE=your_okx_passphrase

BYBIT_API_KEY=your_bybit_key
BYBIT_SECRET_KEY=your_bybit_secret

# ============================================
# SOLANA RPC (On-chain Data)
# ============================================
# Helius: https://www.helius.dev (Free tier: 100k requests/day)
HELIUS_API_KEY=your_helius_key

# QuickNode: https://www.quicknode.com (Free tier: 100k requests/month)
QUICKNODE_API_KEY=your_quicknode_key

# ============================================
# PRICE DATA SOURCES
# ============================================
# CoinGecko: Free, 10-30 req/min, NO API KEY needed
# Binance WebSocket: Free, real-time, NO API KEY needed

# ============================================
# SECURITY
# ============================================
SECURITY_PASSWORD=your_encryption_password

# Demo Settings
DEMO_INITIAL_BALANCE=1000