# AI Brain API
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# ============================================
# EXCHANGE APIs (Trading)
# ============================================
BINANCE_API_KEY=your_binance_key
BINANCE_SECRET_KEY=your_binance_secret

OKX_API_KEY=your_okx_key
OKX_SECRET_KEY=your_okx_secret
OKX_PASSPHRASE=your_okx_passphrase

BYBIT_API_KEY=your_bybit_key
BYBIT_SECRET_KEY=your_bybit_secret

COINBASE_API_KEY=your_coinbase_key
COINBASE_SECRET_KEY=your_coinbase_secret
COINBASE_PASSPHRASE=your_coinbase_passphrase

KRAKEN_API_KEY=your_kraken_key
KRAKEN_SECRET_KEY=your_kraken_secret

# ============================================
# SOLANA RPC (On-chain Data)
# ============================================
# Helius: https://www.helius.dev (Free tier: 100k requests/day)
HELUS_API_KEY=your_helius_key
# QuickNode: https://www.quicknode.com (Free tier: 100k requests/month)
QUICKNODE_API_KEY=your_quicknode_key

# ============================================
# PRICE DATA SOURCES
# ============================================
# CoinGecko: Free, 10-30 req/min, NO API KEY needed for public
# URL: https://api.coingecko.com/api/v3/simple/price
# Binance WebSocket: Free, real-time (millisecond latency), NO API KEY needed
# URL: wss://stream.binance.com:9443/ws
# DIA Free Crypto API: 3000+ tokens, NO API KEY needed
# URL: https://api.diadata.org/v1/

# ============================================
# SOCIAL MEDIA APIs
# ============================================
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ============================================
# SECURITY
# ============================================
SECURITY_PASSWORD=your_encryption_password

# Demo Settings
DEMO_INITIAL_BALANCE=1000
